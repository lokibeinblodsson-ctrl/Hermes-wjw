# Copy these into SnapDeploy's environment variables panel
# (or into a .env file if you deploy via docker compose / upload).

# ---- REQUIRED ----
# Your OpenRouter FREE key (https://openrouter.ai/keys — no card, free catalog)
HERMES_KEY=sk-or-REPLACE_WITH_YOUR_FREE_KEY

# Any long random string (generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=replace-with-a-long-random-string

# ---- OPTIONAL (have sensible defaults) ----
PORT=4000
HERMES_URL=https://openrouter.ai/api/v1
HERMES_MODEL=meta-llama/llama-3.1-8b-instruct:free
